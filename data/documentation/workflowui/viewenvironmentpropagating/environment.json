{"kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"ViewEnvironment","type":"codeVoice"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/WorkflowUI\/documentation\/WorkflowUI","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironmentPropagating"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironmentPropagating\/environment"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15ViewEnvironmentAAV","text":"ViewEnvironment","kind":"typeIdentifier","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"type":"text","text":" and provide those overrides in "},{"code":"customize(environment:)","type":"codeVoice"},{"type":"text","text":". E.g.:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"type":"codeVoice","code":"environmentAncestor"},{"type":"text","text":" to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"type":"codeVoice","code":"environmentDescendant"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" subclasses)."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" conformers ","type":"text"},{"inlineContent":[{"type":"text","text":"must"}],"type":"emphasis"},{"text":" call ","type":"text"},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"layoutSubviews()","type":"codeVoice"},{"text":" respectively.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"}]}],"metadata":{"roleHeading":"Instance Property","modules":[{"name":"WorkflowUI","relatedModules":["ViewEnvironmentUI