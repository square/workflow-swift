{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/WorkflowUI\/documentation\/WorkflowUI","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironmentPropagating"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ViewEnvironment"},{"type":"text","text":" that is flowing through the propagation hierarchy."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV","text":"ViewEnvironment"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to","type":"text"},{"text":" ","type":"text"},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"text":" and provide those overrides in ","type":"text"},{"code":"customize(environment:)","type":"codeVoice"},{"text":". E.g.:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"],"type":"codeListing"},{"inlineContent":[{"text":"By default, this property gets the environment by recursively walking to the root of the","type":"text"},{"text":" ","type":"text"},{"text":"propagation path, and applying customizations on the way back down. The invalidation path may be","type":"text"},{"text":" ","type":"text"},{"text":"interrupted if a node has set it’s ","type":"text"},{"type":"codeVoice","code":"environmentAncestor"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", even if there is a node","type":"text"},{"text":" ","type":"text"},{"text":"which specifies this node as an ","type":"text"},{"type":"codeVoice","code":"environmentDescendant"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you’d like to update the return value of this variable and have those changes propagated through the","type":"text"},{"text":" ","type":"text"},{"text":"propagation hierarchy, conform to ","type":"text"},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"text":" and call ","type":"text"},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"text":" and wait","type":"text"},{"text":" ","type":"text"},{"text":"for the system to call ","type":"text"},{"type":"codeVoice","code":"apply(context:)"},{"text":" when appropriate (e.g. on the next layout pass for","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"UIView"},{"text":" subclasses).","type":"text"}],"type":"paragraph"},{"style":"important","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" conformers "},{"type":"emphasis","inlineContent":[{"type":"text","text":"must"}]},{"type":"text","text":" call "},{"type":"codeVoice","code":"applyEnvironmentIfNeeded()"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"codeVoice","code":"viewWillLayoutSubviews()"},{"text":" and ","type":"text"},{"code":"layoutSubviews()","type":"codeVoice"},{"text":" respectively.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Important"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/workflowui\/viewenvironmentpropagating\/environment"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironmentPropagating\/envir