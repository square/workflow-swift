{"identifier":{"url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironmentPropagating\/environment","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and provide those overrides in "},{"type":"codeVoice","code":"customize(environment:)"},{"type":"text","text":". E.g.:"}],"type":"paragraph"},{"syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"code":"environmentAncestor","type":"codeVoice"},{"type":"text","text":" to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"code":"environmentDescendant","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"text":" ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" subclasses).","type":"text"}],"type":"paragraph"},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" conformers ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"text":" call ","type":"text"},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"layoutSubviews()","type":"codeVoice"},{"type":"text","text":" respectively."}]}],"type":"aside"}]}],"abstract":[{"text":"The ","type":"text"},{"code":"ViewEnvironment","type":"codeVoice"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"kind":"symbol","metadata":{"title":"environment","roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV"}],"ext