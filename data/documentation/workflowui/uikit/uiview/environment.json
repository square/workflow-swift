{"abstract":[{"text":"The ","type":"text"},{"code":"ViewEnvironment","type":"codeVoice"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIView\/environment","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV","text":"ViewEnvironment"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and provide those overrides in "},{"type":"codeVoice","code":"customize(environment:)"},{"type":"text","text":". E.g.:"}]},{"type":"codeListing","syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"type":"paragraph","inlineContent":[{"text":"By default, this property gets the environment by recursively walking to the root of the","type":"text"},{"text":" ","type":"text"},{"text":"propagation path, and applying customizations on the way back down. The invalidation path may be","type":"text"},{"text":" ","type":"text"},{"text":"interrupted if a node has set it’s ","type":"text"},{"code":"environmentAncestor","type":"codeVoice"},{"text":" to ","type":"text"},{"cod