{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","text":"ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"type":"text","text":" and provide those overrides in "},{"code":"customize(environment:)","type":"codeVoice"},{"type":"text","text":". E.g.:"}]},{"type":"codeListing","syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"type":"codeVoice","code":"environmentAncestor"},{"type":"text","text":" to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"type":"codeVoice","code":"environmentDescendant"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" subclasses)."}]},{"type":"aside","name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" conformers "},{"type":"emphasis","inlineContent":[{"type":"text","text":"must"}]},{"type":"text","text":" call "},{"type":"codeVoice","code":"applyEnvironmentIfNeeded()"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"codeVoice","code":"viewWillLayoutSubviews()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"layoutSubviews()"},{"type":"text","text":" respectively."}]}]}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIView\/environment","interfaceLanguage":"swift"},"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ViewEnvironment"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"variants":[{"paths":["\/documentation\/workflowui\/uikit\/uiview\/environment"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Instance Property","externalID":"s:17ViewEnvironmentUI0aB11PropagatingPAAE11environment0aB0AEVvp::SYNTHESIZED::c