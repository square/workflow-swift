ext":"UIView"}],"role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"preciseIdentifier":"c:objc(cs)UIView","kind":"identifier","text":"UIView"}],"abstract":[],"url":"\/documentation\/workflowui\/uikit\/uiview"},"doc://WorkflowUI/documentation/WorkflowUI/ViewEnvironment":{"title":"ViewEnvironment","url":"\/documentation\/workflowui\/viewenvironment","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewEnvironment","kind":"identifier"}],"navigatorTitle":[{"text":"ViewEnvironment","kind":"identifier"}],"role":"symbol","abstract":[{"text":"ViewEnvironment acts as a container for values to flow down the view-side","type":"text"},{"text":" ","type":"text"},{"text":"of a rendering tree (as opposed to being passed down through Workflows).","type":"text"}],"type":"topic"}}}