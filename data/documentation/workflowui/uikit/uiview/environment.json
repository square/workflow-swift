e"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"type":"codeVoice","code":"environmentAncestor"},{"type":"text","text":" to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"type":"codeVoice","code":"environmentDescendant"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"type":"text","text":" and call "},{"code":"setNeedsEnvironmentUpdate()","type":"codeVoice"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"code":"apply(context:)","type":"codeVoice"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" subclasses)."}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" conformers "},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"type":"text","text":" call "},{"type":"codeVoice","code":"applyEnvironmentIfNeeded()"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"codeVoice","code":"viewWillLayoutSubviews()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"layoutSubviews()"},{"type":"text","text":" respectively."}],"type":"paragraph"}],"style":"important","name":"Important"}]}],"sections":[],"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"}