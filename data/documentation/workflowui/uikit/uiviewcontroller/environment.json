xt":" and "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" conformers "},{"inlineContent":[{"type":"text","text":"must"}],"type":"emphasis"},{"type":"text","text":" call "},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"type":"text","text":" in"},{"type":"text","text":" "},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"layoutSubviews()","type":"codeVoice"},{"type":"text","text":" respectively."}]}],"type":"aside"}]}],"abstract":[{"text":"The ","type":"text"},{"code":"ViewEnvironment","type":"codeVoice"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"references":{"doc://WorkflowUI/documentation/WorkflowUI/UIKit":{"kind":"symbol","url":"\/documentation\/workflowui\/uikit","type":"topic","abstract":[],"title":"UIKit","role":"collection","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit"},"doc://WorkflowUI/documentation/WorkflowUI/ViewEnvironment":{"abstract":[{"type":"text","text":"ViewEnvironment acts as a container for values to flow down the view-side"},{"type":"text","text":" "},{"type":"text","text":"of a rendering tree (as opposed to being passed down through Workflows)."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewEnvironment","kind":"identifier"}],"title":"ViewEnvironment","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","url":"\/documentation\/workflowui\/viewenvironment","navigatorTitle":[{"text":"ViewEnvironment","kind":"identifier"}]},"doc://WorkflowUI/documentation/WorkflowUI":{"url":"\/documentation\/workflowui","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI","abstract":[],"role":"collection","type":"topic","title":"WorkflowUI","kind":"symbol"},"doc://WorkflowUI/documentation/WorkflowUI/UIKit/UIViewController/environment":{"type":"topic","role":"symbol","url":"\/documentation\/workflowui\/uikit\/uivie