{"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ViewEnvironment"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"variants":[{"paths":["\/documentation\/workflowui\/uikit\/uiviewcontroller\/environment"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController\/environment"},"metadata":{"externalID":"s:17ViewEnvironmentUI0aB11PropagatingPAAE11environment0aB0AEVvp::SYNTHESIZED::c:objc(cs)UIViewController","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV","kind":"typeIdentifier"}],"modules":[{"relatedModules":["ViewEnvironmentUI"],"name":"WorkflowUI"}],"symbolKind":"property","roleHeading":"Instance Property","extendedModule":"ViewEnvironmentUI","role":"symbol","title":"environment"},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/WorkflowUI\/documentation\/WorkflowUI","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to","type":"text"},{"text":" ","type":"text"},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"text":" and provide those overrides in ","type":"text"},{"code":"customize(environment:)","type":"codeVoice"},{"text":". E.g.:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"type":"codeVoice","code":"environmentAncestor"},{"type":"text","text":" to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"type":"codeVoice","code":"environmentDescendant"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If you’d like to update the return value of this variable and have those changes propagated through the","type":"text"},{"text":" ","type":"text"},{"text":"propagation hierarchy, conform to ","type":"text"},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"text":" and call ","type":"text"},{"code":"setNeedsEnvironmentUpdate()","type":"codeVoice"},{"text":" and wait","type":"text"},{"text":" ","type":"text"},{"text":"for the system to call ","type":"text"},{"code":"apply(context:)","type":"codeVoice"},{"text":" when appropriate (e.g. on the next layout pass for","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" subclasses)."}],"type":"paragraph"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":""},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" and "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" conformers "},{"type":"emphasis","inlineContent":[{"type":"text","text":"must"}]},{"type":"text","text":" call "},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"type":"text","text":" in"},{"type":"text","text":" "},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"layoutSubviews()"},{"type":"text","text":" respectively."}],"type":"paragraph"}],"type":"aside","style":"important"}],"kind":"content"}],"kind":"symbol","references":{"doc://WorkflowUI/documentation/WorkflowUI/UIKit":{"type":"topic","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit","abstract":[],"url":"\/documentation\/workflowui\/uikit","kind":"symbol","title":"UIKit","role":"collection"},"doc://WorkflowUI/documentation/WorkflowUI/UIKit/UIViewController/environment":{"type":"topic","url":"\/documentation\/workflowui\/uikit\/uiviewcontroller\/environment","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController\/environment","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ViewEnvironment"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV"}],"title":"environment"},"doc://WorkflowUI/documentation/WorkflowUI":{"url":"\/documentation\/workflowui","kind":"symbol","role":"collection","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI","type":"topic","title":"WorkflowUI","abstract":[]},"doc://WorkflowUI/documentation/WorkflowUI/ViewEnvironment":{"identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","navigatorTitle":[{"text":"ViewEnvironment","kind":"identifier"}],"type":"topic","title":"ViewEnvironment","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewEnvironment","kind":"identifier"}],"abstract":[{"text":"ViewEnvironment acts as a container for values to flow down the view-side","type":"text"},{"text":" ","type":"text"},{"text":"of a rendering tree (as opposed to being passed down through Workflows).","type":"text"}],"url":"\/documentation\/workflowui\/viewenvironment","role":"symbol","kind":"symbol"},"doc://WorkflowUI/documentation/WorkflowUI/UIKit/UIViewController":{"url":"\/documentation\/workflowui\/uikit\/uiviewcontroller","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"UIViewController"}],"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","text":"UIViewController","preciseIdentifier":"c:objc(cs)UIViewController"}],"title":"UIViewController","type":"topic","abstract":[],"identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController"}}}