{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The "},{"code":"ViewEnvironment","type":"codeVoice"},{"type":"text","text":" that is flowing through the propagation hierarchy."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController\/environment"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/workflowui\/uikit\/uiviewcontroller\/environment"]}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/WorkflowUI\/documentation\/WorkflowUI","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController"]]},"metadata":{"modules":[{"name":"WorkflowUI","relatedModules":["ViewEnvironmentUI"]}],"title":"environment","externalID":"s:17ViewEnvironmentUI0aB11PropagatingPAAE11environment0aB0AEVvp::SYNTHESIZED::c:objc(cs)UIViewController","extendedModule":"ViewEnvironmentUI","symbolKind":"property","role":"symbol","roleHeading":"Instance Property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and provide those overrides in "},{"type":"codeVoice","code":"customize(environment:)"},{"type":"text","text":". E.g.:"}]},{"syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"type":"codeVoice","code":"environmentAncestor"},{"type":"text","text":" to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"type":"codeVoice","code":"environmentDescendant"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" subclasses)."}]},{"content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" conformers "},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"type":"text","text":" call "},{"type":"codeVoice","code":"applyEnvironmentIfNeeded()"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"codeVoice","code":"viewWillLayoutSubviews()"},{"type":"text","text":" and "},{"code":"layoutSubviews()","type":"codeVoice"},{"type":"text","text":" respectively."}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"}]}],"references":{"doc://WorkflowUI/documentation/WorkflowUI/ViewEnvironment":{"title":"ViewEnvironment","url":"\/documentation\/workflowui\/viewenvironment","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewEnvironment","kind":"identifier"}],"navigatorTitle":[{"text":"ViewEnvironment","kind":"identifier"}],"role":"symbol","abstract":[{"text":"ViewEnvironment acts as a container for values to flow down the view-side","type":"text"},{"text":" ","type":"text"},{"text":"of a rendering tree (as opposed to being passed down through Workflows).","type":"text"}],"type":"topic"},"doc://WorkflowUI/documentation/WorkflowUI/UIKit/UIViewController":{"kind":"symbol","role":"symbol","title":"UIViewController","abstract":[],"fragments":[{"text":"extension","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UIViewController","kind":"identifier","preciseIdentifier":"c:objc(cs)UIViewController"}],"identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController","type":"topic","url":"\/documentation\/workflowui\/uikit\/uiviewcontroller","navigatorTitle":[{"kind":"identifier","text":"UIViewController"}]},"doc://WorkflowUI/documentation/WorkflowUI":{"title":"WorkflowUI","abstract":[],"kind