{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/WorkflowUI\/documentation\/WorkflowUI","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit","doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController"]]},"identifier":{"url":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController\/environment","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/workflowui\/uikit\/uiviewcontroller\/environment"]}],"metadata":{"role":"symbol","roleHeading":"Instance Property","externalID":"s:17ViewEnvironmentUI0aB11PropagatingPAAE11environment0aB0AEVvp::SYNTHESIZED::c:objc(cs)UIViewController","symbolKind":"property","title":"environment","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV"}],"modules":[{"relatedModules":["ViewEnvironmentUI"],"name":"WorkflowUI"}],"extendedModule":"ViewEnvironmentUI"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15ViewEnvironmentAAV","text":"ViewEnvironment","kind":"typeIdentifier","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"type":"text","text":" and provide those overrides in "},{"code":"customize(environment:)","type":"codeVoice"},{"type":"text","text":". E.g.:"}]},{"type":"codeListing","syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"type":"paragraph","inlineContent":[{"text":"By default, this property gets the environment by recursively walking to the root of the","type":"text"},{"text":" ","type":"text"},{"text":"propagation path, and applying customizations on the way back down. The invalidation path may be","type":"text"},{"text":" ","type":"text"},{"text":"interrupted if a node has set it’s ","type":"text"},{"type":"codeVoice","code":"environmentAncestor"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", even if there is a node","type":"text"},{"text":" ","type":"text"},{"text":"which specifies this node as an ","type":"text"},{"type":"codeVoice","code":"environmentDescendant"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" subclasses)."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" conformers "},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"type":"text","text":" call "},{"type":"codeVoice","code":"applyEnvironmentIfNeeded()"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"codeVoice","code":"viewWillLayoutSubviews()"},{"text":" and ","type":"text"},{"code":"layoutSubviews()","type":"codeVoice"},{"text":" respectively.","type":"text"}]}],"style":"important","name":"Important"}],"kind":"content"}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ViewEnvironment"},{"type":"text","text":" that is flowing through the propagation hierarchy."}],"references":{"doc://WorkflowUI/documentation/WorkflowUI/UIKit":{"title":"UIKit","role":"collection","type":"topic","kind":"symbol","url":"\/documentation\/workflowui\/uikit","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit","abstract":[]},"doc://WorkflowUI/documentation/WorkflowUI/UIKit/UIViewController":{"abstract":[],"identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/UIKit\/UIViewController","title":"UIViewController","type":"topic","url":"\/documentation\/workflowui\/uikit\/uiviewcontroller","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","preciseIdentifier":"c:objc(cs)UIViewController","text":"UIViewController"}],"navigatorTitle":[{"kind":"identifier","text":"UIViewController"}]},"doc://WorkflowUI/documentation/WorkflowUI":{"abstract":[],"identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI","type":"topic","title":"WorkflowUI","kind":"symbol","role":"collection","url":"\/documentation\/workflowui"},"doc://WorkflowUI/documentation/WorkflowUI/ViewEnvironment":{"kind":"symbol","type":"topic","identifier":"doc:\/\/WorkflowUI\/documentation\/WorkflowUI\/ViewEnvironment","url":"\/documentation\/workflowui\/viewenvironment","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind