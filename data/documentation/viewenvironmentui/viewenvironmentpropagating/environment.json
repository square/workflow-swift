{"sections":[],"metadata":{"symbolKind":"property","externalID":"s:17ViewEnvironmentUI0aB11PropagatingPAAE11environment0aB0AEVvp","modules":[{"name":"ViewEnvironmentUI"}],"roleHeading":"Instance Property","title":"environment","extendedModule":"ViewEnvironmentUI","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15ViewEnvironmentAAV","text":"ViewEnvironment","kind":"typeIdentifier"}],"role":"symbol"},"identifier":{"url":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPropagating\/environment","interfaceLanguage":"swift"},"abstract":[{"text":"The ","type":"text"},{"code":"ViewEnvironment","type":"codeVoice"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI","doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPropagating"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to","type":"text"},{"text":" ","type":"text"},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"text":" and provide those overrides in ","type":"text"},{"code":"customize(environment:)","type":"codeVoice"},{"text":". E.g.:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"code":"environmentAncestor","type":"codeVoice"},{"type":"text","text":" to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"code":"environmentDescendant","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" subclasses)."}],"type":"paragraph"},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" conformers ","type":"text"},{"inlineContent":[{"text":"must","type":"text"}],"type":"emphasis"},{"text":" call ","type":"text"},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"layoutSubviews()"},{"type":"text","text":" respectively."}]}],"type":"aside"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/viewenvironmentui\/viewenvironmentpropagating\/environment"]}],"references":{"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI":{"abstract":[],"identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI","kind":"symbol","title":"ViewEnvironmentUI","role":"collection","type":"topic","url":"\/documentation\/viewenvironmentui"},"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI/ViewEnvironmentPropagating/environment":{"kind":"symbol","role":"symbol","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ViewEnvironment"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ViewEnvironment","kind":"typeIdentifier","preciseIdentifier":"s:15ViewEnvironmentAAV"}],"title":"environment","identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPropagating\/environment","url":"\/documentation\/viewenvironmentui\/viewenvironmentpropagating\/environment"},"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI/ViewEnvironmentPropagating":{"abstract":[{"type":"text","text":"A node in a "},{"type":"codeVoice","code":"ViewEnvironment"},{"type":"text","text":" propagation tree."}],"navigatorTitle":[{"kind":"identifier","text":"ViewEnvironmentPropagating"}],"type":"topic","url":"\/documentation\/viewenvironmentui\/viewenvironmentpropagating","title":"ViewEnvironmentPropagating",