":"UIView","type":"codeVoice"},{"text":" conformers ","type":"text"},{"inlineContent":[{"type":"text","text":"must"}],"type":"emphasis"},{"text":" call ","type":"text"},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"layoutSubviews()","type":"codeVoice"},{"text":" respectively.","type":"text"}]}],"name":"Important"}],"kind":"content"}],"kind":"symbol","references":{"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI/ViewEnvironmentPropagating/environment":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV"}],"type":"topic","kind":"symbol","title":"environment","abstract":[{"text":"The ","type":"text"},{"code":"ViewEnvironment","type":"codeVoice"},{"text":" that is flowing through the propagation hierarchy.","type":"text"}],"identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPropagating\/environment","url":"\/documentation\/viewenvironmentui\/viewenvironmentpropagating\/environment"},"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI":{"url":"\/documentation\/viewenvironmentui","abstract":[],"type":"topic","identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI","kind":"symbol","role":"collection","title":"ViewEnvironmentUI"},"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI/ViewEnvironmentPropagating":{"abstract":[{"type":"text","text":"A node in a "},{"code":"ViewEnvironment","type":"codeVoice"},{"type":"text","text":" propagation tree."}],"url":"\/documentation\/viewenvironmentui\/viewenvironmentpropagating","title":"ViewEnvironmentPropagating","identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPr