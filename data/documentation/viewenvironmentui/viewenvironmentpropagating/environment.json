xt"},{"text":"propagation hierarchy, conform to ","type":"text"},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"text":" and call ","type":"text"},{"code":"setNeedsEnvironmentUpdate()","type":"codeVoice"},{"text":" and wait","type":"text"},{"text":" ","type":"text"},{"text":"for the system to call ","type":"text"},{"code":"apply(context:)","type":"codeVoice"},{"text":" when appropriate (e.g. on the next layout pass for","type":"text"},{"text":" ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" subclasses).","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"UIViewController"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"UIView"},{"text":" conformers ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"must"}]},{"text":" call ","type":"text"},{"type":"codeVoice","code":"applyEnvironmentIfNeeded()"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"viewWillLayoutSubviews()"},{"text":" and ","type":"text"},{"code":"layoutSubviews()","type":"codeVoice"},{"text":" respectively.","type":"text"}]}],"type":"aside","style":"important","name":"Important"}],"kind":"content"}],"identifier":{"url":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPropagating\/environment","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI","doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/ViewEnvironmentPropagating"]]},"variants":[{"paths":["\/documentation\/viewenvironmentui\/viewenvironmentpropagating\/environment"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"externalID":"s:17ViewEnvironmentUI0aB11PropagatingPAAE11environment0aB0AEVvp","role":"symbol","title":"environment","symbolKind":"property","frag