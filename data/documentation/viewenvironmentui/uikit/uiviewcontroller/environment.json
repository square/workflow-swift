","code":"customize(environment:)"},{"type":"text","text":". E.g.:"}]},{"type":"codeListing","syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"type":"paragraph","inlineContent":[{"text":"By default, this property gets the environment by recursively walking to the root of the","type":"text"},{"text":" ","type":"text"},{"text":"propagation path, and applying customizations on the way back down. The invalidation path may be","type":"text"},{"text":" ","type":"text"},{"text":"interrupted if a node has set it’s ","type":"text"},{"code":"environmentAncestor","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", even if there is a node","type":"text"},{"text":" ","type":"text"},{"text":"which specifies this node as an ","type":"text"},{"code":"environmentDescendant","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"type":"text","text":" and call "},{"code":"setNeedsEnvironmentUpdate()","type":"codeVoice"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"code":"apply(context:)","type":"codeVoice"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"text":" ","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" subclasses).","type":"text"}]},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":""},{"code":"UIViewController","type":"codeVoice"},{"type":"text","text":" and "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" conformers "},{"inlineContent":[{"type":"text","text":"must"}],"type":"emphasis"},{"type":"text","text":" call "},{"code":"applyEnvironmentIfNeeded()","type":"codeVoice"},{"type":"text","text":" in"},{"type":"text","text":" "},{"code":"viewWillLayoutSubviews()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"layoutSubviews()","type":"codeVoice"},{"type":"text","text":" respectively."}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/viewenvironmentui\/uikit\/uiviewcontroller\/environment"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","references":{"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI/UIKit/UIViewController":{"navigatorTitle":[{"kind":"identifier","text":"UIViewController"}],"kind":"symbol","abstract":[],"fragments":[{"kind":"keyword","text":"extension"},{"kind":"text","text":" "},{"kind":"identifier","text":"UIViewController","preciseIdentifier":"c:objc(cs)UIViewController"}],"url":"\/documentation\/viewenvironmentui\/uikit\/uiviewcontroller","role":"symbol","type":"topic","identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/UIKit\/UIViewController","title":"UIViewController"},"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI":{"identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI","kind":"symbol","title":"ViewEnvironmentUI","url":"\/documentation\/viewenvironmentui","type":"topic","role":"collection","abstract":[]},"doc://ViewEnvironmentUI/documentation/ViewEnvironmentUI/UIKit/UIViewController/environment":{"type":"topic","title":"environment","identifier":"doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/UIKit\/UIViewController\/environment","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ViewEnvironment","preciseIdentifier":"s:15ViewEnvironmentAAV"}],"abstract":[{"type":"text","text":