":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"]},{"inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"code":"environmentAncestor","type":"codeVoice"},{"type":"text","text":" to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", even if there is a node"},{"type":"text","text":" "},{"type":"text","text":"which specifies this node as an "},{"code":"environmentDescendant","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you’d like to update the return value of this variable and have those changes propagated through the"},{"type":"text","text":" "},{"type":"text","text":"propagation hierarchy, conform to "},{"type":"codeVoice","code":"ViewEnvironmentObserving"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"setNeedsEnvironmentUpdate()"},{"type":"text","text":" and wait"},{"type":"text","text":" "},{"type":"text","text":"for the system to call "},{"type":"codeVoice","code":"apply(context:)"},{"type":"text","text":" when appropriate (e.g. on the next layout pass for"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" subclasses)."}],"type":"paragraph"},{"name":"Important","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"UIViewController","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UIView","type":"codeVoice"},{"text":" conformers ","type":"text"},{"inlineContent":[{"type":"text","text":"must"}],"type":"emph