{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI","doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/UIKit","doc:\/\/ViewEnvironmentUI\/documentation\/ViewEnvironmentUI\/UIKit\/UIViewController"]]},"kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ViewEnvironment"},{"type":"text","text":" that is flowing through the propagation hierarchy."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15ViewEnvironmentAAV","kind":"typeIdentifier","text":"ViewEnvironment"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If you’d like to provide overrides for the environment as it flows through a node, you should conform to"},{"type":"text","text":" "},{"code":"ViewEnvironmentObserving","type":"codeVoice"},{"type":"text","text":" and provide those overrides in "},{"code":"customize(environment:)","type":"codeVoice"},{"type":"text","text":". E.g.:"}],"type":"paragraph"},{"syntax":"swift","code":["func customize(environment: inout ViewEnvironment) {","    environment.traits.mode = .dark","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"By default, this property gets the environment by recursively walking to the root of the"},{"type":"text","text":" "},{"type":"text","text":"propagation path, and applying customizations on the way back down. The invalidation path may be"},{"type":"text","text":" "},{"type":"text","text":"interrupted if a node has set it’s "},{"code":"environmentAncestor","type":"codeVoice"},{"type":"text","text":" to "},