{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/workflow\/rendercontext"]}],"hierarchy":{"paths":[["doc:\/\/Workflow\/documentation\/Workflow"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"RenderContext"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"WorkflowType"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"WorkflowType"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/Workflow\/documentation\/Workflow\/Workflow","preciseIdentifier":"s:8WorkflowAAP","kind":"typeIdentifier","text":"Workflow"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"During a render pass, a workflow may want to defer to a child"},{"type":"text","text":" "},{"type":"text","text":"workflow to render some portion of its content. For example,"},{"type":"text","text":" "},{"type":"text","text":"a workflow that renders to a split-screen view model might"},{"type":"text","text":" "},{"type":"text","text":"delegate to child A for the left side, and child B for the right"},{"type":"text","text":" "},{"type":"text","text":"side view models. Nesting allows for a fractal tree that is constructed"},{"type":"text","text":" "},{"type":"text","text":"out of many small parts."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a parent wants to delegate to a child workflow, it must first"},{"type":"text","text":" "},{"type":"text","text":"create an instance of that workflow. This can be thought of as the"},{"type":"text","text":" "},{"type":"text","text":"model of the child workflow. It does not contain any active state,"},{"type":"text","text":" "},{"type":"text","text":"it simply contains the data necessary to create or update a workflow"},{"type":"text","text":" "},{"type":"text","text":"node."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The parent then calls "},{"code":"render(workflow:outputMap:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"with two values:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The child workflow."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A closure that transforms the child’s output events into the parent’s","type":"text"},{"text":" ","type":"text"},{"code":"Event","type":"codeVoice"},{"text":" type so that the parent can respond to events generated by","type":"text"},{"text":" ","type":"text"},{"text":"the child.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"If the parent had previously rendered a child of the same type, the existing"},{"type":"text","text":" "},{"type":"text","text":"child workflow node is updated."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the parent had not rendered a child of the same type in the previous"},{"type":"text","text":" "},{"type":"text","text":"render pass, a new child workflow node is generated."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The infrastructure then performs a render pass on the child to obtain its"},{"type":"text","text":" "},{"code":"Rendering","type":"codeVoice"},{"type":"text","text":" value, which is then returned to the caller."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"code":"RenderContext","type":"codeVoice"},{"type":"text","text":" is the composition point for the workflow tree."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Workflow\/documentation\/Workflow\/RenderContext"},"topicSections":[{"generated":true,"identifiers":["doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeOutputSink