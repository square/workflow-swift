{"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RenderContext","kind":"identifier"},{"text":"<","kind":"text"},{"text":"WorkflowType","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WorkflowType","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Workflow","kind":"typeIdentifier","identifier":"doc:\/\/Workflow\/documentation\/Workflow\/Workflow","preciseIdentifier":"s:8WorkflowAAP"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"During a render pass, a workflow may want to defer to a child","type":"text"},{"text":" ","type":"text"},{"text":"workflow to render some portion of its content. For example,","type":"text"},{"text":" ","type":"text"},{"text":"a workflow that renders to a split-screen view model might","type":"text"},{"text":" ","type":"text"},{"text":"delegate to child A for the left side, and child B for the right","type":"text"},{"text":" ","type":"text"},{"text":"side view models. Nesting allows for a fractal tree that is constructed","type":"text"},{"text":" ","type":"text"},{"text":"out of many small parts.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a parent wants to delegate to a child workflow, it must first"},{"type":"text","text":" "},{"type":"text","text":"create an instance of that workflow. This can be thought of as the"},{"type":"text","text":" "},{"type":"text","text":"model of the child workflow. It does not contain any active state,"},{"type":"text","text":" "},{"type":"text","text":"it simply contains the data necessary to create or update a workflow"},{"type":"text","text":" "},{"type":"text","text":"node."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The parent then calls "},{"code":"render(workflow:outputMap:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"with two values:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The child workflow.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A closure that transforms the child’s output events into the parent’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Event"},{"text":" type so that the parent can respond to events generated by","type":"text"},{"text":" ","type":"text"},{"text":"the child.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"If the parent had previously rendered a child of the same type, the existing"},{"type":"text","text":" "},{"type":"text","text":"child workflow node is updated."}],"type":"paragraph"},{"inlineContent":[{"text":"If the parent had not rendered a child of the same type in the previous","type":"text"},{"text":" ","type":"text"},{"text":"render pass, a new child workflow node is generated.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The infrastructure then performs a render pass on the child to obtain its","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Rendering"},{"text":" value, which is then returned to the caller.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/workflow\/rendercontext"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/Workflow\/documentation\/Workflow\/RenderContext","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/Workflow\/documentation\/Workflow"]]},"sections":[],"metadata":{"title":"RenderContext","role":"symbol","roleHeading":"Class","modules":[{"name":"Workflow"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RenderContext","kind":"identifier"}],"navigatorTitle":[{"text":"RenderContext","kind":"identifier"}],"externalID":"s:8Workflow13RenderContextC","symbolKind":"class"},"abstract":[{"code":"RenderContext","type":"codeVoice"},{"text":" is the composition point for the workflow tree.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeOutputSink()","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeSink(of:)","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeSink(of:onEvent:)","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeStateMutationSink()","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/runSideEffect(key:action:)"],"generated":true,"title":"Instance Methods","anchor":"Instance-Methods"}],"references":{"doc://Workflow/documentation/Workflow/RenderContext/makeStateMutationSink()":{"url":"\/documentation\/workflow\/rendercontext\/makestatemutationsink()","abstract":[{"type":"text","text":"Creates "},{"type":"codeVoice","code":"StateMutationSink"},{"type":"text","text":"."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeStateMutationSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"StateMutationSink","preciseIdentifier":"s:8Workflow17StateMutationSinkV","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"WorkflowType","preciseIdentifier":"s:8Workflow13RenderContextC0A4Typexmfp","kind":"typeIdentifier"},{"text":">","kind":"text"}],"conformance":{"conformancePrefix":[{"type":"text","text":"Conforms when"}],"constraints":[{"type":"codeVoice","code":"WorkflowType"},{"type":"text","text":" conforms to "},{"type":"codeVoice","code":"Workflow"},{"type":"text","text":"."}],"availabilityPrefix":[{"type":"text","text":"Available when"}]},"identifier":"doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeStateMutationSink()","type":"topic","kind":"symbol","role":"symbol","title":"makeStateMutationSink()"},"doc://Workflow/documentation/Workflow/RenderContext/ru