{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","abstract":[{"type":"codeVoice","code":"RenderContext"},{"type":"text","text":" is the composition point for the workflow tree."}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeOutputSink()","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeSink(of:)","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeSink(of:onEvent:)","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeStateMutationSink()","doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/runSideEffect(key:action:)"],"title":"Instance Methods","anchor":"Instance-Methods"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"RenderContext"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"WorkflowType"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"WorkflowType"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:8WorkflowAAP","kind":"typeIdentifier","text":"Workflow","identifier":"doc:\/\/Workflow\/documentation\/Workflow\/Workflow"}]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"During a render pass, a workflow may want to defer to a child","type":"text"},{"text":" ","type":"text"},{"text":"workflow to render some portion of its content. For example,","type":"text"},{"text":" ","type":"text"},{"text":"a workflow that renders to a split-screen view model might","type":"text"},{"text":" ","type":"text"},{"text":"delegate to child A for the left side, and child B for the right","type":"text"},{"text":" ","type":"text"},{"text":"side view models. Nesting allows for a fractal tree that is constructed","type":"text"},{"text":" ","type":"text"},{"text":"out of many small parts.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a parent wants to delegate to a child workflow, it must first"},{"type":"text","text":" "},{"type":"text","text":"create an instance of that workflow. This can be thought of as the"},{"type":"text","text":" "},{"type":"text","text":"model of the child workflow. It does not contain any active state,"},{"type":"text","text":" "},{"type":"text","text":"it simply contains the data necessary to create or update a workflow"},{"type":"text","text":" "},{"type":"text","text":"node."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parent then calls "},{"type":"codeVoice","code":"render(workflow:outputMap:)"},{"type":"text","text":" "},{"type":"text","text":"with two values:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The child workflow.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A closure that transforms the child’s output events into the parent’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"Event"},{"type":"text","text":" type so that the parent can respond to events generated by"},{"type":"text","text":" "},{"type":"text","text":"the child."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"If the parent had previously rendered a child of the same type, the existing","type":"text"},{"text":" ","type":"text"},{"text":"child workflow node is updated.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the parent had not rendered a child of the same type in the previous"},{"type":"text","text":" "},{"type":"text","text":"render pass, a new child workflow node is generated."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The infrastructure then performs a render pass on the child to obtain its"},{"type":"text","text":" "},{"type":"codeVoice","code":"Rendering"},{"type":"text","text":" value, which is then returned to the caller."}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/workflow\/rendercontext"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Class","role":"symbol","modules":[{"name":"Workflow"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RenderContext","kind":"identifier"}],"title":"RenderContext","externalID":"s:8Workflow13RenderContextC","symbolKind":"class","navigatorTitle":[{"text":"RenderContext","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/Workflow\/documentation\/Workflow"]]},"identifier":{"url":"doc:\/\/Workflow\/documentation\/Workflow\/RenderContext","interfaceLanguage":"swift"},"references":{"doc://Workflow/documentation/Workflow/RenderContext/makeSink(of:)":{"identifier":"doc:\/\/Workflow\/documentation\/Workflow\/RenderContext\/makeSink(of:)","title":"makeSink(of:)","kind":"symbol","abstract":[{"text":"Creates a ","type":"text"},{"code":"Sink","type":"codeVoice"},{"text":" that can be used to send ","type":"text"},{"code":"Action","type":"codeVoice"},{"text":"s.","type":"text"}],"role":"symbol","url":"\/documentation\/workflow\/rendercontext\/makesink(of:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"makeSink"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Action"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Action","preciseIdentifier":"s:8Workflow13RenderContextC8makeSink2ofAA0E0Vyqd__Gqd__m_t0A4TypeQyd__RszAA0A6ActionRd__lF0H0L_qd__mfp"},{"kind":"text","text":".Type) -> "},{"kind":"typeIdentifier","text":"Sink","preciseIdentifier":"s:8Workflow4SinkV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Action","preciseIdentifier":"s:8Workflow13RenderContextC8makeSink2ofAA0E0Vyqd__Gqd__m_t0A4TypeQyd__RszAA0A6ActionRd__lF0H0L_qd__mf